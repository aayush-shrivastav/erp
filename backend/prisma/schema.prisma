generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ACADEMIC_ADMIN
  ACCOUNTS_ADMIN
  ACCOUNTANT
  FACULTY
  STUDENT
}

enum FundingType {
  SELF
  DRCC
  SCHOLARSHIP
}

enum BatchType {
  B1
  B2
  B3
  B4
  ALL
}

enum SubjectType {
  THEORY
  PRACTICAL
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum ExamType {
  SESSIONAL
  MID_SEM
  END_SEM
}

enum TargetAudience {
  ALL
  STUDENTS
  FACULTY
  DEPARTMENT
  SEMESTER
}

enum FeeStatus {
  PAID
  PARTIAL
  UNPAID
  PENDING
}

enum FineReason {
  LATE_PAYMENT // "Late Payment"
  LIBRARY_DAMAGE // "Library Damage"
  ID_CARD_REISSUE // "ID Card Reissue"
  HOSTEL_LATE // "Hostel Late"
  MANUAL_PENALTY // "Manual Penalty"
}

enum FeeType {
  COLLEGE_FEE
  BUS_FEE
  FINE
}

enum PaymentSource {
  SELF
  DRCC
  SCHOLARSHIP
}

enum PaymentMode {
  CASH
  UPI
  BANK
  CARD
  ONLINE
  DD
}

enum TransactionStatus {
  SUCCESS
  FAILED
  REFUNDED
}

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  password              String
  role                  Role
  isActive              Boolean   @default(true)
  lastLogin             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  student               Student?
  faculty               Faculty?
  
  noticesCreated        Notice[]
  paymentsCollected     Payment[]     @relation("collectedBy")
  paymentsCreated       Payment[]     @relation("createdBy")
  paymentsUpdated       Payment[]     @relation("updatedBy")
  transactionsCreated   Transaction[] @relation("txnCreatedBy")
  transactionsUpdated   Transaction[] @relation("txnUpdatedBy")
  editHistories         EditHistory[] @relation("editedBy")
  manualFinesAdded      ManualFine[]
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  headOfDepartmentId String?   @unique
  headOfDepartment   Faculty?  @relation("HeadOfDepartment", fields: [headOfDepartmentId], references: [id])
  
  students    Student[]
  courses     Course[]
  faculties   Faculty[]
  sections    Section[]
  subjects    Subject[]
  notices     Notice[]
}

model Course {
  id             String   @id @default(uuid())
  name           String
  departmentId   String
  department     Department @relation(fields: [departmentId], references: [id])
  durationYears  Int
  totalSemesters Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  students       Student[]
  semesters      Semester[]
  sections       Section[]
  feeStructures  FeeStructure[]
}

model AcademicSession {
  id        String   @id @default(uuid())
  year      String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  semesters Semester[] @relation("SessionSemesters")
  attendances Attendance[]
  marks       Mark[]
  fees        Fee[]
}

model Semester {
  id        String   @id @default(uuid())
  name      String
  level     Int
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  sessionId String?
  session   AcademicSession? @relation("SessionSemesters", fields: [sessionId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  students  Student[]
  sections  Section[]
  subjects  Subject[]
  notices   Notice[]
  feeStructures FeeStructure[]
  transactions  Transaction[]
}

model Section {
  id               String    @id @default(uuid())
  name             String
  departmentId     String
  department       Department @relation(fields: [departmentId], references: [id])
  semesterId       String
  semester         Semester   @relation(fields: [semesterId], references: [id])
  courseId         String
  course           Course     @relation(fields: [courseId], references: [id])
  classTeacherId   String?
  classTeacher     Faculty?   @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  capacity         Int        @default(60)
  baseRollNumber   Int
  currentRollIndex Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  
  students         Student[]
  labGroups        LabGroup[]
  subjectAssignments SubjectAssignment[]
  timetables       Timetable[]
  attendances      Attendance[]
  marks            Mark[]
}

model Faculty {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  employeeId   String   @unique
  name         String
  phone        String?
  designation  String?
  joiningDate  DateTime?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  headOfDepartmentOf Department? @relation("HeadOfDepartment")
  classTeacherOf     Section[]   @relation("ClassTeacher")
  mentoring          Student[]   @relation("StudentMentor")
  
  facultySubjects    FacultySubject[]
  subjectAssignments SubjectAssignment[]
  timetables         Timetable[]
  attendances        Attendance[]
  marks              Mark[]
}

model Student {
  id               String     @id @default(uuid())
  userId           String     @unique
  user             User       @relation(fields: [userId], references: [id])
  enrollmentNo     String     @unique
  universityRollNo String?    @unique
  name             String
  phone            String?
  admissionDate    DateTime?
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id])
  courseId         String?
  course           Course?     @relation(fields: [courseId], references: [id])
  currentSemesterId String?
  currentSemester  Semester?   @relation(fields: [currentSemesterId], references: [id])
  sectionId        String?
  section          Section?    @relation(fields: [sectionId], references: [id])
  labGroupId       String?
  labGroup         LabGroup?   @relation(fields: [labGroupId], references: [id])
  batch            BatchType?
  mentorId         String?
  mentor           Faculty?    @relation("StudentMentor", fields: [mentorId], references: [id])
  fundingType      FundingType @default(SELF)
  isPassout        Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  
  attendanceRecords AttendanceRecord[]
  markRecords       MarkRecord[]
  studentFees       StudentFee[]
  studentLedger     StudentLedger?
  transactions      Transaction[]
  editHistories     EditHistory[]
  payments          Payment[]
  receipts          Receipt[]
  fees              Fee[]
}


model Subject {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  type         SubjectType
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  semesterId   String?
  semester     Semester?   @relation(fields: [semesterId], references: [id])
  credits      Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  facultySubjects    FacultySubject[]
  subjectAssignments SubjectAssignment[]
  timetables         Timetable[]
  attendances        Attendance[]
  marks              Mark[]
}

// Join table for Faculty many-to-many Subjects
model FacultySubject {
  facultyId String
  faculty   Faculty @relation(fields: [facultyId], references: [id])
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])
  
  @@id([facultyId, subjectId])
}

model SubjectAssignment {
  id        String   @id @default(uuid())
  facultyId String
  faculty   Faculty  @relation(fields: [facultyId], references: [id])
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([facultyId, subjectId, sectionId])
}

model Timetable {
  id        String    @id @default(uuid())
  sectionId String
  section   Section   @relation(fields: [sectionId], references: [id])
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  subjectId String
  subject   Subject   @relation(fields: [subjectId], references: [id])
  facultyId String
  faculty   Faculty   @relation(fields: [facultyId], references: [id])
  roomNo    String
  batch     BatchType @default(ALL)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Attendance {
  id        String   @id @default(uuid())
  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id])
  date      DateTime
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id])
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  facultyId String
  faculty   Faculty  @relation(fields: [facultyId], references: [id])
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  records   AttendanceRecord[]
}

model AttendanceRecord {
  id           String     @id @default(uuid())
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  status       String     // PRESENT, ABSENT, LATE
}

model Mark {
  id          String   @id @default(uuid())
  examType    ExamType
  mstNumber   Int?     // 1,2,3 for MST1,MST2,MST3; null for others
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  sectionId   String
  section     Section  @relation(fields: [sectionId], references: [id])
  labGroupId  String?  // For lab subgroups
  labGroup    LabGroup? @relation(fields: [labGroupId], references: [id])
  facultyId   String
  faculty     Faculty  @relation(fields: [facultyId], references: [id])
  isLocked    Boolean  @default(false)
  isFinalized Boolean  @default(false)
  maxMarks    Float
  assignmentMarks Float?  @default(0)
  attendanceMarks Float? @default(0)
  finalMst    Float?
  finalMarks  Float?
  overrideMarks Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  records     MarkRecord[]
}

model MarkRecord {
  id            String   @id @default(uuid())
  markId        String
  mark          Mark     @relation(fields: [markId], references: [id])
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  marksObtained Float    // MST score for that number, assignment/att/final as per mark type
}


model Notice {
  id               String         @id @default(uuid())
  title            String
  content          String
  createdById      String
  createdBy        User           @relation(fields: [createdById], references: [id])
  targetAudience   TargetAudience
  targetDepartmentId String?
  targetDepartment Department?    @relation(fields: [targetDepartmentId], references: [id])
  targetSemesterId String?
  targetSemester   Semester?      @relation(fields: [targetSemesterId], references: [id])
  attachments      String[]       // Array of URLs
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model FeeStructure {
  id            String   @id @default(uuid())
  courseId      String
  course        Course   @relation(fields: [courseId], references: [id])
  semesterId    String
  semester      Semester @relation(fields: [semesterId], references: [id])
  tuitionFee    Float
  labFee        Float    @default(0)
  libraryFee    Float    @default(0)
  otherCharges  Float    @default(0)
  totalAmount   Float
  dueDate       DateTime
  finePerDay    Float    @default(0)
  maxFineLimit  Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  studentFees   StudentFee[]
  
  @@unique([courseId, semesterId])
}

model StudentFee {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  feeStructureId String
  feeStructure  FeeStructure @relation(fields: [feeStructureId], references: [id])
  
  totalAmount   Float
  paidAmount    Float    @default(0)
  
  autoFineAmount Float   @default(0)
  totalManualFineAmount Float @default(0)
  totalFineAmount Float  @default(0)
  totalPayable  Float
  remainingBalance Float
  
  status        FeeStatus @default(UNPAID)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  manualFines   ManualFine[]
  transactions  Transaction[]
  payments      Payment[]
  
  @@unique([studentId, feeStructureId])
}

model ManualFine {
  id            String     @id @default(uuid())
  studentFeeId  String
  studentFee    StudentFee @relation(fields: [studentFeeId], references: [id])
  amount        Float
  reason        FineReason
  description   String?
  dateAdded     DateTime   @default(now())
  addedById     String?
  addedBy       User?      @relation(fields: [addedById], references: [id])
}

model StudentLedger {
  id              String   @id @default(uuid())
  studentId       String   @unique
  student         Student  @relation(fields: [studentId], references: [id])
  
  totalFee        Float    @default(0)
  paidAmount      Float    @default(0)
  pendingAmount   Float    @default(0)
  
  // JSON fields to store nested data easily without extra models for every small thing
  collegeFee      Json     @default("{\"total\": 0, \"paid\": 0, \"pending\": 0}")
  busFee          Json     @default("{\"total\": 0, \"paid\": 0, \"pending\": 0, \"route\": null}")
  fine            Json     @default("{\"total\": 0, \"paid\": 0, \"pending\": 0}")
  paymentsBySource Json    @default("{\"SELF\": 0, \"DRCC\": 0, \"SCHOLARSHIP\": 0}")
  
  lastPaymentDate DateTime?
  lastPaymentAmount Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Transaction {
  id              String   @id @default(uuid())
  receiptNo       String   @unique
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  feeType         FeeType
  semesterId      String?
  semester        Semester? @relation(fields: [semesterId], references: [id])
  amount          Float
  paymentSource   PaymentSource
  paymentMode     PaymentMode
  transactionId   String
  paymentDate     DateTime @default(now())
  busRoute        String?
  fineReason      String?
  fineDescription String?
  
  createdById     String
  createdBy       User     @relation("txnCreatedBy", fields: [createdById], references: [id])
  updatedById     String?
  updatedBy       User?    @relation("txnUpdatedBy", fields: [updatedById], references: [id])
  
  status          TransactionStatus @default(SUCCESS)
  isReversed      Boolean  @default(false)
  
  relatedFeeId    String?
  relatedFee      StudentFee? @relation(fields: [relatedFeeId], references: [id])
  
  editHistories   EditHistory[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([studentId, feeType])
  @@index([studentId, createdAt(sort: Desc)])
  @@index([feeType])
  @@index([paymentSource])
}

model EditHistory {
  id               String   @id @default(uuid())
  transactionRefId String
  transactionRef   Transaction @relation(fields: [transactionRefId], references: [id])
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id])
  oldAmount        Float
  newAmount        Float
  editedById       String
  editedBy         User     @relation("editedBy", fields: [editedById], references: [id])
  editedAt         DateTime @default(now())
  reason           String
  
  oldPaymentMode   String?
  newPaymentMode   String?
  oldPaymentSource String?
  newPaymentSource String?
  oldTransactionId String?
  newTransactionId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Payment {
  id            String   @id @default(uuid())
  receiptNo     String   @unique
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  studentFeeId  String
  studentFee    StudentFee @relation(fields: [studentFeeId], references: [id])
  
  amountPaid    Float
  paymentMode   PaymentMode
  paymentSource PaymentSource
  transactionId String
  paymentDate   DateTime @default(now())
  
  collectedById String?
  collectedBy   User?    @relation("collectedBy", fields: [collectedById], references: [id])
  createdById   String
  createdBy     User     @relation("createdBy", fields: [createdById], references: [id])
  updatedById   String?
  updatedBy     User?    @relation("updatedBy", fields: [updatedById], references: [id])
  
  status        TransactionStatus @default(SUCCESS)
  isReversed    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  receipts      Receipt[]
}

model Receipt {
  id            String   @id @default(uuid())
  receiptNumber String   @unique
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  paymentId     String
  payment       Payment  @relation(fields: [paymentId], references: [id])
  
  amountPaid    Float
  paymentMode   String
  transactionId String?
  paymentDate   DateTime
  
  baseFeePaid   Float    @default(0)
  finePaid      Float    @default(0)
  remainingBalance Float
  
  pdfUrl        String?
  rawPdfData    Bytes?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Fee {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  sessionId   String
  session     AcademicSession @relation(fields: [sessionId], references: [id])
  totalAmount Float
  paidAmount  Float    @default(0)
  dueDate     DateTime
  status      FeeStatus @default(PENDING)
  
  components  Json     @default("{\"tuitionFee\": 0, \"libraryFee\": 0, \"transportFee\": 0, \"otherFee\": 0}")
  payments    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id                  String   @id @default(uuid())
  collegeName         String   @default("EduNexus B.Tech ERP")
  address             String   @default("123 University Avenue")
  contactEmail        String   @default("admin@edunexus.edu")
  contactPhone        String   @default("+1 (555) 123-4567")
  currentAcademicYear String   @default("2023-2024")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model LabGroup {
  id              String   @id @default(uuid())
  name            String   // e.g. "3C11"
  parentSectionId String
  parentSection   Section  @relation(fields: [parentSectionId], references: [id])
  capacity        Int      @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  marks           Mark[]
  students        Student[]
  
  @@unique([parentSectionId, name])
}

